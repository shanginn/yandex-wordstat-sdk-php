{
    "name": "shanginn/yandex-wordstat",
    "description": "A strongly-typed, modern PHP SDK for the Yandex Wordstat API",
    "version": "0.2.0",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Shanginn\\YandexWordstat\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/serializer": "^7",
        "symfony/property-access": "^7",
        "crell/serde": "^1.3",
        "amphp/http-client": "^5.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "symfony/var-dumper": "^7.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
